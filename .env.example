# FORGE Stack — Environment Variables
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
#   nano .env

# z.ai (GLM-4.7) — Required for RLM reasoning
ZAI_API_KEY=

# Jina AI — Required for semantic skill search (primary)
JINA_API_KEY=

# Exa — Optional, for internet-aware web search
EXA_API_KEY=
