# FORGE Stack — Environment Variables
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
#   nano .env

# z.ai (GLM-4.7) — Required for GLM Bridge reasoning (coding plan)
ZAI_API_KEY=

# z.ai (GLM-4.7-Flash) — FREE tier for Self-Refine critique
# Get from: https://z.ai/manage-apikey (use a free-tier account)
ZAI_FLASH_API_KEY=

# Jina AI — Required for semantic skill search (primary)
JINA_API_KEY=

# Exa — Optional, for internet-aware web search
EXA_API_KEY=
